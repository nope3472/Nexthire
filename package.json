{
  "name": "nexthire-desktop",
  "version": "1.0.0",
  "description": "NextHire Desktop Application - Screenshot capture & OAuth authentication",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "electron .",
    "start": "npm run build && electron .",
    "dist:win": "dotenv -e .env -- npm run build && dotenv -e .env -- electron-builder --win --config build/electron-builder.yml",
    "dist:mac": "dotenv -e .env -- npm run build && dotenv -e .env -- electron-builder --mac --config build/electron-builder.yml",
    "dist:all": "dotenv -e .env -- npm run build && dotenv -e .env -- electron-builder --win --mac --config build/electron-builder.yml",
    "sign:mac": "codesign --deep --force --sign \"-\" dist/mac/NextHire.app",
    "gen:cert": "powershell -ExecutionPolicy Bypass -File scripts/generate-cert.ps1",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src"
  },
  "keywords": [
    "electron",
    "desktop",
    "screenshot",
    "oauth"
  ],
  "author": "NextHire",
  "license": "MIT",
  "dependencies": {
    "@workos-inc/node": "^7.36.0",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
